{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.1.0",
  "description": "__MSG_extDesc__",
  "default_locale": "zh_CN",
  "permissions": [
    "cookies",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://youdao.com/*",
    "https://*.youdao.com/*",
    "http://youdao.com/*",
    "http://*.youdao.com/*"
  ],
  "options_page": "settings.html",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
